// Skillozen Prisma Schema
// PostgreSQL database schema for the full platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── PARENT / ACCOUNT ────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  password     String?
  plan         Plan      @default(FREE)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  children     Child[]
  toolUsages   ToolUsage[]
  sessions     Session[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique @default(cuid())
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("sessions")
}
enum Plan {
  FREE      // Feature 1 only
  STANDARD  // Feature 1 + 2  (₹499/yr)
  PREMIUM   // Feature 1 + 2 + 3  (₹799/yr)
}

// ─── CHILD PROFILE ────────────────────────────────────────────────────────────

model Child {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  age         Int       // 4–20
  avatarEmoji String    @default("🧒")
  
  // XP & Gamification
  totalXp     Int       @default(0)
  level       Int       @default(1)
  streakDays  Int       @default(0)
  lastActive  DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  assessments       Assessment[]
  skillProfiles     SkillProfile[]
  activityLogs      ActivityLog[]
  badges            ChildBadge[]
  exams         Exam[]
  goals         Goal[]
  weeklyReports WeeklyReport[]
  seenQuestions Json?
  @@map("children")
}

// ─── ASSESSMENT (Feature 1) ───────────────────────────────────────────────────

model Assessment {
  id          String            @id @default(cuid())
  childId     String
  child       Child             @relation(fields: [childId], references: [id], onDelete: Cascade)

  status      AssessmentStatus  @default(IN_PROGRESS)
  currentQ    Int               @default(0)   // 0–19
  totalQ      Int               @default(20)

  answers     AssessmentAnswer[]
  skillProfile SkillProfile?

  startedAt   DateTime          @default(now())
  completedAt DateTime?
  questionOrder Json?
  @@map("assessments")
}

enum AssessmentStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model AssessmentAnswer {
  id            String     @id @default(cuid())
  assessmentId  String
  assessment    Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  questionIndex Int
  questionText  String
  skill         SkillArea
  answerText    String
  score         Int        // 0–10 score for this answer
  reasoning     String?    // AI reasoning

  createdAt     DateTime   @default(now())

  @@map("assessment_answers")
}

// ─── SKILL PROFILE (Assessment Results) ──────────────────────────────────────

model SkillProfile {
  id            String   @id @default(cuid())
  childId       String
  child         Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  assessmentId  String   @unique
  assessment    Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  // 0-100 scores per skill area — Original 5
  criticalThinking  Int
  communication     Int
  socialEmotional   Int
  creativity        Int
  digitalLiteracy   Int

  // 0-100 scores per skill area — New 5
  financialLiteracy   Int @default(0)
  healthWellness      Int @default(0)
  goalSetting         Int @default(0)
  scientificThinking  Int @default(0)
  publicSpeaking      Int @default(0)

  overallScore      Int
  ageGroup          AgeGroup

  // AI-generated insights
  strengths         String[]
  gaps              String[]
  recommendations   String[]
  summary           String

  // Benchmarks vs age group (percentile 0-100) — Original 5
  criticalThinkingPct  Int @default(50)
  communicationPct     Int @default(50)
  socialEmotionalPct   Int @default(50)
  creativityPct        Int @default(50)
  digitalLiteracyPct   Int @default(50)

  // Benchmarks vs age group (percentile 0-100) — New 5
  financialLiteracyPct  Int @default(50)
  healthWellnessPct     Int @default(50)
  goalSettingPct        Int @default(50)
  scientificThinkingPct Int @default(50)
  publicSpeakingPct     Int @default(50)

  createdAt     DateTime @default(now())

  @@map("skill_profiles")
}

enum SkillArea {
  CRITICAL_THINKING
  COMMUNICATION
  SOCIAL_EMOTIONAL
  CREATIVITY
  DIGITAL_LITERACY
  FINANCIAL_LITERACY
  HEALTH_WELLNESS
  GOAL_SETTING
  SCIENTIFIC_THINKING
  PUBLIC_SPEAKING
}

enum AgeGroup {
  EARLY    // 4–7
  MIDDLE   // 8–12
  TEEN     // 13–17
  YOUNG_ADULT // 18–20
}

// ─── TRAINING ACTIVITIES (Feature 2) ─────────────────────────────────────────

model Activity {
  id          String      @id @default(cuid())
  title       String
  description String
  skill       SkillArea
  ageGroup    AgeGroup[]
  type        ActivityType
  difficulty  Int         @default(1) // 1–5
  xpReward    Int         @default(10)
  durationMin Int         @default(10)
  content     Json        // flexible content payload
  tags        String[]
  isActive    Boolean     @default(true)
  isOffline   Boolean     @default(false)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  logs        ActivityLog[]

  @@map("activities")
}

enum ActivityType {
  QUIZ
  SIMULATION
  CREATIVE_TASK
  REFLECTION
  CHALLENGE
  GAME
}

model ActivityLog {
  id          String   @id @default(cuid())
  childId     String
  child       Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  activityId  String
  activity    Activity @relation(fields: [activityId], references: [id])

  xpEarned    Int
  score       Int?     // 0-100 if applicable
  completedAt DateTime @default(now())

  @@map("activity_logs")
}

// ─── BADGES ───────────────────────────────────────────────────────────────────

model Badge {
  id          String    @id @default(cuid())
  name        String
  emoji       String
  description String
  condition   String    // human-readable unlock condition
  xpThreshold Int?      // optional XP threshold
  skill       SkillArea?

  children    ChildBadge[]

  @@map("badges")
}

model ChildBadge {
  id        String   @id @default(cuid())
  childId   String
  child     Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  badgeId   String
  badge     Badge    @relation(fields: [badgeId], references: [id])
  earnedAt  DateTime @default(now())

  @@unique([childId, badgeId])
  @@map("child_badges")
}

// ─── ANALYTICS ────────────────────────────────────────────────────────────────

model ToolUsage {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  feature   String   // "assessment" | "training" | "dashboard"
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  @@map("tool_usages")
}

// ─── ADMIN ────────────────────────────────────────────────────────────────────

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  @@map("admins")
}
model Exam {
  id           String       @id @default(cuid())
  childId      String
  child        Child        @relation(fields: [childId], references: [id], onDelete: Cascade)
  name         String
  academicYear String
  examDate     DateTime?
  totalMarks   Int          @default(100)
  subjects     ExamSubject[]
  results      ExamResult[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  @@map("exams")
}

model ExamSubject {
  id       String       @id @default(cuid())
  examId   String
  exam     Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  name     String
  maxMarks Int          @default(100)
  order    Int          @default(0)
  results  ExamResult[]
  @@map("exam_subjects")
}

model ExamResult {
  id            String      @id @default(cuid())
  examId        String
  exam          Exam        @relation(fields: [examId], references: [id], onDelete: Cascade)
  subjectId     String
  subject       ExamSubject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  childId       String
  marksObtained Float
  grade         String?
  remarks       String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  @@unique([examId, subjectId])
  @@map("exam_results")
}

model Goal {
  id           String     @id @default(cuid())
  childId      String
  child        Child      @relation(fields: [childId], references: [id], onDelete: Cascade)
  type         GoalType
  title        String
  description  String?
  skill        SkillArea?
  targetScore  Int?
  subject      String?
  targetMarks  Float?
  examName     String?
  currentValue Float      @default(0)
  achieved     Boolean    @default(false)
  achievedAt   DateTime?
  deadline     DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  @@map("goals")
}

model WeeklyReport {
  id                  String   @id @default(cuid())
  childId             String
  child               Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  weekStart           DateTime
  weekEnd             DateTime
  summary             String
  highlights          String[]
  concerns            String[]
  recommendations     String[]
  encouragement       String
  activitiesCompleted Int      @default(0)
  xpEarned            Int      @default(0)
  skillsImproved      String[]
  createdAt           DateTime @default(now())
  @@map("weekly_reports")
}

enum GoalType {
  SKILL
  ACADEMIC
}
