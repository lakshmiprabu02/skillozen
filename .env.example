# ─── Database ────────────────────────────────────────────────────────────────
# Get from your PostgreSQL provider (Supabase, Neon, Railway, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/skillozen?sslmode=require"

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Change to your production domain on Vercel:
# NEXT_PUBLIC_APP_URL="https://skillozen.vercel.app"

# ─── Admin ────────────────────────────────────────────────────────────────────
# Secret key for admin JWT tokens — use a long random string
ADMIN_JWT_SECRET="change-this-to-a-long-random-secret-string-at-least-32-chars"
ADMIN_PASSWORD="admin@skillozen2024"   # Change before production!

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_MAX="60"          # Max requests per window
RATE_LIMIT_WINDOW_MS="60000" # Window in ms (60 seconds)
